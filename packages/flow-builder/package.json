{
    "name": "@flowkit/flow-builder",
    "version": "0.1.0",
    "description": "Portable, configurable visual node-builder canvas: palette, schema-driven forms, typed connections, serialization",
    "license": "Apache-2.0",
    "publishConfig": {
        "access": "public"
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./styles.css": "./dist/styles.css"
    },
    "files": [
        "dist"
    ],
    "sideEffects": [
        "**/*.css"
    ],
    "scripts": {
        "build": "tsc && vite build",
        "clean": "rimraf dist",
        "lint": "eslint \"src/**/*.{ts,tsx}\"",
        "test": "jest",
        "test:watch": "jest --watch"
    },
    "peerDependencies": {
        "@emotion/react": "^11.10.0",
        "@emotion/styled": "^11.10.0",
        "@flowkit/ui-foundation": "^0.1.0",
        "@mui/icons-material": "^5.0.0",
        "@mui/material": "^5.15.0",
        "notistack": "^2.0.4",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "reactflow": "^11.5.0"
    },
    "dependencies": {
        "@tabler/icons-react": "^3.30.0",
        "clsx": "^1.1.1",
        "lodash": "^4.17.21",
        "prop-types": "^15.7.2"
    },
    "devDependencies": {
        "@emotion/react": "^11.10.6",
        "@emotion/styled": "^11.10.6",
        "@flowkit/ui-foundation": "workspace:*",
        "@mui/icons-material": "5.0.3",
        "@mui/material": "5.15.0",
        "@mui/x-data-grid": "6.8.0",
        "@types/jest": "^29.5.14",
        "@types/lodash": "^4.14.195",
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@vitejs/plugin-react": "^4.2.0",
        "jest": "^29.7.0",
        "notistack": "^2.0.4",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "reactflow": "^11.5.6",
        "rimraf": "^5.0.5",
        "ts-jest": "^29.3.2",
        "typescript": "^5.4.5",
        "vite": "^5.0.2",
        "vite-plugin-dts": "^3.7.0"
    }
}
