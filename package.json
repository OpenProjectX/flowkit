{
    "name": "flowkit",
    "version": "0.1.0",
    "private": true,
    "description": "A common, abstract, portable, configurable visual-builder UI kit (extracted from Flowise)",
    "license": "Apache-2.0",
    "scripts": {
        "build": "pnpm -r --sort build",
        "test": "pnpm -r test",
        "lint": "eslint \"packages/*/src/**/*.{ts,tsx}\" \"examples/*/src/**/*.{ts,tsx,js,jsx}\"",
        "lint:fix": "eslint \"packages/*/src/**/*.{ts,tsx}\" \"examples/*/src/**/*.{ts,tsx,js,jsx}\" --fix",
        "clean": "pnpm -r clean",
        "nuke": "rimraf node_modules packages/*/node_modules examples/*/node_modules",
        "changeset": "changeset",
        "version-packages": "changeset version",
        "release": "pnpm -r --sort build && changeset publish"
    },
    "devDependencies": {
        "@typescript-eslint/eslint-plugin": "^8.18.2",
        "@typescript-eslint/parser": "^8.18.2",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.1.3",
        "eslint-plugin-react": "^7.34.0",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-unused-imports": "^3.1.0",
        "prettier": "^2.7.1",
        "rimraf": "^5.0.5",
        "typescript": "^5.4.5",
        "@changesets/cli": "^2.27.1"
    },
    "prettier": {
        "printWidth": 140,
        "singleQuote": true,
        "jsxSingleQuote": true,
        "trailingComma": "none",
        "tabWidth": 4,
        "semi": false,
        "endOfLine": "auto"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "packageManager": "pnpm@10.33.2"
}
